PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/furniture_configurator
JWT_SECRET=change-me-to-a-long-random-hex-string
JWT_EXPIRE=7d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
# Planner'ın kök adresi — CMS'teki "Planner'da Aç" showroom bağlantısını buradan kurar.
# Boş bırakılırsa ALLOWED_ORIGINS'in ilkine düşer; prod'da mutlaka doldurun.
PLANNER_URL=http://localhost:5173
PLANNER_CLIENT_KEY=change-me-to-a-long-random-hex-string
MONGO_ROOT_PASSWORD=change-me-if-using-docker-compose-mongo

# Cloudflare R2 (icon/3D model yüklemeleri için, S3 uyumlu API)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=furniture-bucket
R2_CDN_URL=https://pub-a3ce010822b64aaaaea5e17cb19ef77b.r2.dev

# Ters proxy arkasındaysa (nginx / Cloudflare / PaaS) kaç katman olduğunu yazın —
# rate limit'in gerçek istemci IP'sini görebilmesi için gerekli. Doğrudan internete
# açıksa BOŞ BIRAKIN: proxy yokken "güven" açmak, saldırganın X-Forwarded-For
# uydurup IP limitini tamamen atlamasına izin verir.
TRUST_PROXY=

# Public teklif ucunun saatlik TAVANI (tüm IP'ler toplamı). IP başına limit dağıtık
# bir saldırıda işe yaramaz; her kabul edilen istek Mongo'ya kayıt + R2'ye görsel
# demek olduğu için toplam bir tavan da gerekiyor. Boşsa 100 kabul edilir.
QUOTE_GLOBAL_HOURLY_MAX=100
